<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="repository.vcf.dbn" version="1.0.0" name="Valencia CF DBN Repository" provider-name="DBN">
        <requires>
            <import addon="xbmc.addon" version="12.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Valencia CF DBN Repository">
            <info compressed="false">https://danielet21.github.io/repository.vcf.dbn/addons.xml</info>
            <checksum>https://danielet21.github.io/repository.vcf.dbn/addons.xml.md5</checksum>
            <datadir zip="true">https://danielet21.github.io/repository.vcf.dbn/zips</datadir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es">Repositorio oficial del skin Valencia CF DBN</summary>
            <description lang="es">Repositorio con el skin Valencia CF DBN y sus addons para Kodi 21 (Omega)</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="skin.vcf.dbn" version="1.0.0" name="VCF DBN Skin" provider-name="DBN">
        <requires>
            <import addon="xbmc.gui" version="5.15.0"/>
        </requires>
        <extension point="xbmc.gui.skin" defaultresolution="1080i">
            <res width="1920" height="1080" aspect="16x9" default="true" folder="1080i"/>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es">Skin Valencia CF para Kodi 21</summary>
            <description lang="es">Skin temática Valencia CF con colores naranja y negro, widget próximo partido y música ambiente</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="script.vcf.nextmatch" version="1.0.0" name="VCF Next Match" provider-name="DBN">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.python.script" library="default.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.service" library="service.py" start="startup"/>
        <extension point="xbmc.addon.metadata">
            <summary lang="es">Valencia CF - Próximo Partido</summary>
            <description lang="es">Muestra el próximo partido del Valencia CF en la pantalla principal</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
